AI_COACH_API_KEY=
AI_COACH_MODEL=llama-3.3-70b-versatile

# Backward-compatible server key used by the existing Vercel project.
GROQ_API_KEY=

# Public browser credentials from the FocuzNow Supabase project.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Existing server-only download endpoint. Never expose the service role key.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Existing beta-site switch retained for compatible preview deployments.
VITE_BETA_SITE=false

# Embedded Stripe Elements billing. Secret values must only be set in Vercel.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=

# Browser store destinations. Chromium variants fall back to the Chrome URL.
VITE_CHROME_EXTENSION_URL=
VITE_EDGE_EXTENSION_URL=
VITE_OPERA_EXTENSION_URL=
