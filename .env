# Local dev: copy to .env and set your keys
GROQ_API_KEY=

# Supabase (client — safe to expose with VITE_ prefix)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server — Vercel /api/download only, never expose to browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Set to "true" on localhost to preview the beta tester site
VITE_BETA_SITE=true
