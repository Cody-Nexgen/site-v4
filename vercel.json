{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/privacy.html",
            "destination": "/privacy.html"
        },
        {
            "source": "/terms.html",
            "destination": "/terms.html"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/auth/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
